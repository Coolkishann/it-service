generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  officeId  Int?
  workUpdates WorkUpdate[]
  assignedCalls ServiceCall[]
  createdAt DateTime @default(now())
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  officeId  Int
  createdAt DateTime @default(now())
  branches  Branch[]
}

model Branch {
  id   Int    @id @default(autoincrement())
  name String

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  officeId Int

  createdAt DateTime @default(now())

  devices Device[] // ⭐ ADD THIS LINE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ENGINEER
}

enum DeviceCategory {
  LAPTOP
  DESKTOP
  PRINTER
  AIO
}

enum ProcessorType {
  INTEL_I3
  INTEL_I5
  INTEL_I7
  AMD_RYZEN5
  AMD_RYZEN7
}

model Device {
  id Int @id @default(autoincrement())

  category DeviceCategory
  company  String
  model    String

  serialNumber String @unique

  ram     String?
  storage String?
  os      String?

  motherboardName   String?
  motherboardSerial String?

  processor ProcessorType?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  officeId Int

  serviceCalls ServiceCall[]

  createdAt DateTime @default(now())
}


enum CallStatus {
  PENDING
  UNDER_OBSERVATION
  RESOLVED
}

model ServiceCall {
  id          Int      @id @default(autoincrement())

  problem     String
  errorCode   String?

  status      CallStatus @default(PENDING)

  deviceId    Int
  device      Device @relation(fields: [deviceId], references: [id])

  engineerId  Int?
  engineer    User?  @relation(fields: [engineerId], references: [id])

  officeId    Int
workUpdates WorkUpdate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkUpdate {
  id          Int      @id @default(autoincrement())

  description String

  serviceCallId Int
  serviceCall   ServiceCall @relation(fields: [serviceCallId], references: [id])

  engineerId Int
  engineer   User @relation(fields: [engineerId], references: [id])

  createdAt DateTime @default(now())
images WorkImage[]
  spareParts SparePart[]
}

model SparePart {
  id        Int      @id @default(autoincrement())

  partName  String
  capacity  String?

  oldSerial String?
  newSerial String?

  workUpdateId Int
  workUpdate   WorkUpdate @relation(fields: [workUpdateId], references: [id])

  createdAt DateTime @default(now())
}

model WorkImage {
  id           Int @id @default(autoincrement())

  imageUrl     String
  type         ImageType

  workUpdateId Int
  workUpdate   WorkUpdate @relation(fields: [workUpdateId], references: [id])

  createdAt DateTime @default(now())
}

enum ImageType {
  BEFORE
  AFTER
}